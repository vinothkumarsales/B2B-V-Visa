APP_MODE=demo
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required only when APP_MODE=production
DATABASE_URL=
SESSION_SECRET=

# Zoho CRM - server only. Do not use NEXT_PUBLIC_ for these keys.
CRM_SYNC_ENABLED=false
CRM_WRITE_ENABLED=false
CRM_ATTACHMENT_SYNC_ENABLED=false
CRM_ABANDONED_LEAD_ENABLED=false
CRM_ABANDONED_LEAD_DELAY_MINUTES=15
CRM_PAYMENT_CONVERSION_ENABLED=false
ZOHO_CRM_CLIENT_ID=
ZOHO_CRM_CLIENT_SECRET=
ZOHO_CRM_REFRESH_TOKEN=
ZOHO_CRM_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_CRM_API_BASE_URL=https://www.zohoapis.in
ZOHO_CRM_TRAVEL_AGENTS_MODULE=Travel_Agents
ZOHO_CRM_LEADS_MODULE=Leads
ZOHO_CRM_CONTACTS_MODULE=Contacts
ZOHO_CRM_DEALS_MODULE=Deals
ZOHO_CRM_TASKS_MODULE=Tasks
ZOHO_CRM_NOTES_MODULE=Notes
ZOHO_CRM_TRANSACTIONS_MODULE=
ZOHO_CRM_APPLICATIONS_MODULE=
ZOHO_CRM_SERVICES_MODULE=

# Zoho Payments - server only.
ZOHO_PAYMENTS_CLIENT_ID=
ZOHO_PAYMENTS_CLIENT_SECRET=
ZOHO_PAYMENTS_REFRESH_TOKEN=
ZOHO_PAYMENTS_ACCOUNT_ID=
ZOHO_PAYMENTS_ORG_ID=
ZOHO_PAYMENTS_API_BASE_URL=
ZOHO_PAYMENTS_WEBHOOK_SECRET=

# Digio OCR - server only.
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=
DIGIO_BASE_URL=https://api.digio.in
DIGIO_ENVIRONMENT=sandbox

# Private document storage.
STORAGE_PROVIDER=local
STORAGE_PRIVATE_ROOT=upload/private
