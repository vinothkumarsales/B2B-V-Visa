APP_MODE=demo
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Required only when APP_MODE=production
DATABASE_URL=
SESSION_SECRET=

# Google OAuth - server only. Configure the redirect URI as:
# https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Temporary emergency admin bootstrap login. Server-only; never expose with NEXT_PUBLIC_*.
# Prefer ADMIN_BOOTSTRAP_PASSWORD_HASH generated by the app password hashing scheme.
ADMIN_BOOTSTRAP_LOGIN_ENABLED=false
ADMIN_BOOTSTRAP_PASSWORD_HASH=
ADMIN_BOOTSTRAP_PASSWORD=

# Shared Zoho OAuth - server only. Do not use NEXT_PUBLIC_ for these keys.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.in
ZOHO_API_DOMAIN=https://www.zohoapis.in

# Zoho CRM product configuration.
CRM_SYNC_ENABLED=false
CRM_WRITE_ENABLED=false
CRM_ATTACHMENT_SYNC_ENABLED=false
CRM_ABANDONED_LEAD_ENABLED=false
CRM_ABANDONED_LEAD_DELAY_MINUTES=15
CRM_PAYMENT_CONVERSION_ENABLED=false
ZOHO_CRM_TRAVEL_AGENTS_MODULE=Travel_Agents
ZOHO_CRM_SERVICES_MODULE=Service_Requests
ZOHO_CRM_LEADS_MODULE=Leads
ZOHO_CRM_CONTACTS_MODULE=Contacts
ZOHO_CRM_ACCOUNTS_MODULE=Accounts
ZOHO_CRM_DEALS_MODULE=Deals
ZOHO_CRM_TASKS_MODULE=Tasks
ZOHO_CRM_NOTES_MODULE=Notes
ZOHO_CRM_API_VERSION=v8
ZOHO_CRM_TRANSACTIONS_MODULE=
ZOHO_CRM_APPLICATIONS_MODULE=

